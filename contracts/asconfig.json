{
  "targets": {
    "token": {
      "outFile": "build/OpLaunchToken.wasm",
      "use": ["abort=src/token/index/abort"]
    },
    "curve": {
      "outFile": "build/BondingCurve.wasm",
      "use": ["abort=src/bonding-curve/index/abort"]
    },
    "staking": {
      "outFile": "build/StakingVault.wasm",
      "use": ["abort=src/staking-vault/index/abort"]
    },
    "factory": {
      "outFile": "build/TokenFactory.wasm",
      "use": ["abort=src/token-factory/index/abort"]
    }
  },
  "options": {
    "sourceMap": false,
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": false,
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ],
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 1,
    "exportStart": "start",
    "transform": "@btc-vision/opnet-transform"
  }
}
